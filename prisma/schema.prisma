generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  email     String   @unique
  password  String
  avatar    String?
  bio       String?
  role      String   @default("user")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  posts     Post[]
  comments  Comment[]
}

model Post {
  id        String   @id @default(uuid())
  title     String
  slug      String   @unique
  excerpt   String?
  content   String
  cover     String?
  published Boolean  @default(false)
  views     Int      @default(0)
  category  String   @default("未分类")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  tags      PostTag[]
  comments  Comment[]
}

model PostTag {
  id     String @id @default(uuid())
  name   String
  postId String
  post   Post   @relation(fields: [postId], references: [id])
  @@unique([name, postId])
}

model Comment {
  id        String   @id @default(uuid())
  content   String
  createdAt DateTime @default(now())
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  postId    String
  post      Post     @relation(fields: [postId], references: [id])
}
